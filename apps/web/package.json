{
  "name": "@oddtrust/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "start:ws": "tsx ws-server.ts",
    "start:worker": "tsx worker.ts",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "tsx -e 'import { loadEnv } from \"./lib/config\"; import { createLogger } from \"./lib/logger\"; import { createPostgresPool, runMigrations } from \"./lib/postgres\"; import { join } from \"path\"; loadEnv(); createLogger(); createPostgresPool({ connectionString: process.env.DATABASE_URL! }); runMigrations(join(__dirname, \"migrations\")).then(() => { console.log(\"Migrations complete\"); process.exit(0); }).catch((e) => { console.error(e); process.exit(1); });'"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@oddtrust/design-tokens": "workspace:*",
    "@oddtrust/ui": "workspace:*",
    "@solana/web3.js": "^2.0.0",
    "bullmq": "^5.0.0",
    "dotenv": "^16.4.0",
    "ioredis": "^5.4.0",
    "next": "16.2.10",
    "pg": "^8.13.0",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "prom-client": "^15.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.11.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.5.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.0.0",
    "typescript": "^5",
    "vitest": "^3.0.0"
  }
}
