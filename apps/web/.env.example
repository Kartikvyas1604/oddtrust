# ══════════════════════════════════════════════════════════════════════════════
# OddsTrust Web Dashboard — Environment Configuration
# Next.js 16 App Router with WebSocket server and background worker
# ══════════════════════════════════════════════════════════════════════════════
#
# Copy to: apps/web/.env.local
# Or run:  pnpm --filter @oddtrust/web setup
#
# ══════════════════════════════════════════════════════════════════════════════


# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
WS_PORT=3002
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://oddtrust:oddtrust_dev@localhost:5432/oddtrust
REDIS_URL=redis://localhost:6379

# ─── TxLINE Data Source ─────────────────────────────────────────────────────
# Sign up: https://txline.txodds.com
TXLINE_API_BASE=https://api.txline.txodds.com/v1
TXLINE_WS_URL=wss://stream.txline.txodds.com/v1
TXLINE_CLIENT_ID=your_client_id_here
TXLINE_WALLET_KEY=your_wallet_key_here

# ─── Solana Blockchain ──────────────────────────────────────────────────────
# Devnet default. Leave SOLANA_ORACLE_PROGRAM_ID empty for simulation mode.
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_ORACLE_PROGRAM_ID=
SOLANA_PAYER_KEY=

# ─── Redis Pub/Sub ──────────────────────────────────────────────────────────
REDIS_PROOF_FEED_CHANNEL=proof-feed:live

# ─── Rate Limiting ──────────────────────────────────────────────────────────
API_RATE_LIMIT_MAX=100
API_RATE_LIMIT_WINDOW_MS=60000

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=true
