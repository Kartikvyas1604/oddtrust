# ─── Server ────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
WS_PORT=3002
NODE_ENV=development

# ─── Database ──────────────────────────────────────────
DATABASE_URL=postgres://oddtrust:oddtrust_dev@localhost:5432/oddtrust
REDIS_URL=redis://localhost:6379

# ─── TxLINE ────────────────────────────────────────────
# Base URL for the TxLINE REST API
TXLINE_API_BASE=https://api.txline.txodds.com/v1
# WebSocket URL for the TxLINE live odds stream
TXLINE_WS_URL=wss://stream.txline.txodds.com/v1
# Client ID obtained from TxLINE dashboard
TXLINE_CLIENT_ID=your_client_id_here
# Wallet private key for signing the TxLINE subscription
TXLINE_WALLET_KEY=your_wallet_key_here

# ─── Solana ────────────────────────────────────────────
# RPC endpoint (devnet default, change to mainnet for production)
SOLANA_RPC_URL=https://api.devnet.solana.com
# Oracle program ID (leave empty for simulation mode)
SOLANA_ORACLE_PROGRAM_ID=
# Payer keypair for on-chain submission fees
SOLANA_PAYER_KEY=

# ─── Logging ───────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=true

# ─── Redis Pub/Sub Channels ────────────────────────────
REDIS_PROOF_FEED_CHANNEL=proof-feed:live

# ─── Rate Limiting ─────────────────────────────────────
API_RATE_LIMIT_MAX=100
API_RATE_LIMIT_WINDOW_MS=60000
