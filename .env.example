# ══════════════════════════════════════════════════════════════════════════════
# OddsTrust — On-Chain Trust Oracle
# Complete environment configuration for all services
# ══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env.local in the relevant app directory:
#   cp .env.example apps/web/.env.local
#   cp .env.example apps/backend/.env.local
#
# Or run the interactive setup:
#   pnpm --filter @oddtrust/web setup
#
# ══════════════════════════════════════════════════════════════════════════════


# ─── Application ─────────────────────────────────────────────────────────────
# Environment: development | production | test
NODE_ENV=development

# ─── Server Ports ────────────────────────────────────────────────────────────
# Web dashboard port (apps/web)
PORT=3000
# WebSocket server port for live proof feed (apps/web/ws-server.ts)
WS_PORT=3002
# Backend API port (apps/backend)
# PORT=3001

# Bind address for all services
HOST=0.0.0.0


# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://oddtrust:oddtrust_dev@localhost:5432/oddtrust

# Redis connection string (used for caching, queues, and pub/sub)
# Format: redis://HOST:PORT
REDIS_URL=redis://localhost:6379


# ─── TxLINE Data Source ─────────────────────────────────────────────────────
# TxLINE provides live sports betting odds data
# Sign up at https://txline.txodds.com for API credentials

# REST API base URL for fixtures and historical odds
TXLINE_API_BASE=https://api.txline.txodds.com/v1

# WebSocket URL for real-time odds streaming
TXLINE_WS_URL=wss://stream.txline.txodds.com/v1

# Your TxLINE client ID (required — get from TxLINE dashboard)
TXLINE_CLIENT_ID=your_client_id_here

# Wallet private key for signing TxLINE subscriptions (required)
# WARNING: Never commit real private keys. Use placeholder values in committed files.
TXLINE_WALLET_KEY=your_wallet_key_here


# ─── Solana Blockchain ──────────────────────────────────────────────────────
# RPC endpoint for Solana transactions
# Devnet:  https://api.devnet.solana.com
# Mainnet: https://api.mainnet-beta.solana.com (use a dedicated RPC provider)
# Localnet: http://127.0.0.1:8899
SOLANA_RPC_URL=https://api.devnet.solana.com

# On-chain program ID for the OddsTrust oracle
# Leave empty to run in simulation mode (no on-chain writes)
# Deployed program: HooVY5etEhNnPWouvZhzGCgbTjBfk3mff66S8jFgaAit
SOLANA_ORACLE_PROGRAM_ID=

# Payer keypair for on-chain transaction fees (Base58, JSON array, or hex)
# Leave empty to run in simulation mode
# WARNING: Never commit real private keys.
SOLANA_PAYER_KEY=


# ─── Redis Pub/Sub ──────────────────────────────────────────────────────────
# Channel name for broadcasting proof feed events to WebSocket clients
REDIS_PROOF_FEED_CHANNEL=proof-feed:live


# ─── Rate Limiting ──────────────────────────────────────────────────────────
# Maximum requests per window per IP
API_RATE_LIMIT_MAX=100
# Window duration in milliseconds (60000 = 1 minute)
API_RATE_LIMIT_WINDOW_MS=60000


# ─── Logging ────────────────────────────────────────────────────────────────
# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
# Enable pretty-printed logs in development (false in production)
LOG_PRETTY=true


# ─── Replay Mode ────────────────────────────────────────────────────────────
# Number of fixtures to replay when running `pnpm --filter @oddtrust/backend replay`
REPLAY_FIXTURE_COUNT=50
